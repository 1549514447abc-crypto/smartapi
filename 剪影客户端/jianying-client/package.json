{
    "name": "jianying-client",
    "version": "1.0.0",
    "description": "剪映草稿导入工具",
    "main": "main.js",
    "author": "长沙芯跃科技有限公司",
    "license": "MIT",
    "scripts": {
        "start": "npx electron .",
        "dev": "npx electron . --inspect",
        "electron": "npx electron .",
        "server": "node server.js",
        "dev:full": "concurrently \"npm run server\" \"npm run dev\"",
        "test": "echo \"No tests specified\" && exit 0",
        "build": "electron-builder --win",
        "build:win": "electron-builder --win",
        "pack": "electron-builder --dir"
    },
    "keywords": [
        "jianying",
        "video",
        "electron",
        "desktop"
    ],
    "build": {
        "appId": "cn.contentcube.jianying-client",
        "productName": "剪映小助手",
        "copyright": "Copyright © 2025 长沙芯跃科技有限公司",
        "directories": {
            "output": "dist"
        },
        "files": [
            "**/*",
            "!dist/**/*",
            "!node_modules/.cache/**/*"
        ],
        "win": {
            "target": [
                {
                    "target": "nsis",
                    "arch": ["x64"]
                }
            ]
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true,
            "createDesktopShortcut": true,
            "createStartMenuShortcut": true,
            "shortcutName": "剪映小助手"
        }
    },
    "devDependencies": {
        "electron": "^25.8.4",
        "electron-builder": "^24.13.3",
        "concurrently": "^8.2.2"
    },
    "dependencies": {
        "express": "^4.18.2",
        "cors": "^2.8.5",
        "qrcode": "^1.5.3",
        "axios": "^1.6.0",
        "dotenv": "^16.3.1"
    }
}
