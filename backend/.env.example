# Server Configuration
PORT=your_value_here
NODE_ENV=your_value_here

# Database Configuration
DB_HOST=your_value_here
DB_PORT=your_value_here
DB_NAME=your_value_here
DB_USER=your_value_here
DB_PASSWORD=your_value_here

# JWT Configuration
JWT_SECRET=your_value_here
JWT_EXPIRES_IN=your_value_here

# Supabase Configuration
# Supabase配置已迁移到数据库 api_configs 表中
# 可通过管理后台或数据库直接配置

# Aliyun SMS Configuration (阿里云短信配置)
ALIYUN_SMS_ENABLED=true
ALIYUN_SMS_ACCESS_KEY_ID=your_access_key_id
ALIYUN_SMS_ACCESS_KEY_SECRET=your_access_key_secret
ALIYUN_SMS_SIGN_NAME=your_sign_name
ALIYUN_SMS_TEMPLATE_CODE=SMS_123456789
ALIYUN_SMS_TEMPLATE_CODE_REGISTER=SMS_123456789
ALIYUN_SMS_TEMPLATE_CODE_RESET=SMS_123456789
ALIYUN_SMS_ENDPOINT=dysmsapi.aliyuncs.com

# WeChat MP Configuration (微信公众号配置)
WECHAT_MP_TOKEN=your_wechat_token
WECHAT_APP_ID=your_wechat_app_id
WECHAT_APP_SECRET=your_wechat_app_secret
